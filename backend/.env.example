SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
AES_SECRET_KEY=64-character-hex-string-here

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
BACKEND_URL=http://localhost:8000
ENVIRONMENT=development

# CORS — default "*" already covers chrome-extension://* origins.
# allow_credentials is forced to False in main.py when using wildcard origins,
# which is required by the CORS spec (credentials + wildcard is not allowed).
CORS_ORIGINS=*
